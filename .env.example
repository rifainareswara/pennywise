# Database
DATABASE_URL=postgresql://pennywise:pennywise@localhost:5432/pennywise
POSTGRES_DB=pennywise
POSTGRES_USER=pennywise
POSTGRES_PASSWORD=pennywise

# Backend
JWT_SECRET=pennywise-dev-secret-change-in-production
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated list for multiple deployed frontend origins
